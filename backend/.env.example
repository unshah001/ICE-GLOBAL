# =========================
# APP
# =========================
NODE_ENV=development
APP_NAME=ICEGLOBAL
APP_HOST=0.0.0.0
APP_PORT=8082


APP_BASE_URL=http://192.168.1.72:8082
WEB_BASE_URL=http://192.168.1.72:8080

# =========================
# LOGGING
# =========================
LOG_LEVEL=info
DEBUG_MODE=true

# =========================
# SECURITY / AUTH (JWT)
# =========================
# Strong random secret for signing access tokens
JWT_ACCESS_SECRET=change_me_access_secret_very_long_random
JWT_ACCESS_TTL=15d

# Strong random secret for signing refresh tokens
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long_random
JWT_REFRESH_TTL=30d

# Optional: if you want to allow only certain origins in production
CORS_ORIGINS=*

# =========================
# DATABASE - MONGODB
# =========================
MONGO_URI=mongodb://mongo:secret@localhost:27017/?authSource=admin
MONGO_DB_NAME=ICE_app

# =========================
# REDIS
# =========================
REDIS_URL=redis://:sanjay12@localhost:6379/0
REDIS_PREFIX=iceapp
REDIS_PASSWORD="sanjay12"

# BullMQ queue settings
QUEUE_CONCURRENCY_UPLOAD=6
QUEUE_CONCURRENCY_LLM=6

# Max upload size in bytes (default: 5MB)
UPLOAD_MAX_BYTES=5242880

# Folder to store uploaded files
UPLOAD_TMP_DIR=./uploads



# =========================
# RATE LIMITING (Fastify rate-limit)
# =========================
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1m

# =========================
# OPTIONAL METRICS
# =========================
METRICS_ENABLED=false



# SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="task.mymovies@gmail.com"
SMTP_PASS="cbdufbyeikivuqjt"
EMAIL_FROM="task.mymovies@gmail.com"
SMTP_FROM="Revision <task.mymovies@gmail.com>"



#Defautl-Admin
USER_NAME="admin"
PASSWORD="admin@998877"

# Media paths
# Publicly reachable base URL for generated assets (served by your static host or CDN)
MEDIA_BASE_URL="http://192.168.1.72:8082/upload"
# Filesystem directory where uploads are stored
MEDIA_STORAGE_PATH="./storage/media"
BUNNY_STORAGE_ZONE="iceglobal"
BUNNY_STORAGE_PASSWORD="31533b15-6192-4922-a11be90648c4-8c21-412f"
BUNNY_STORAGE_REGION=""
BUNNY_PULL_BASE_URL="https://ice-global.b-cdn.net"


